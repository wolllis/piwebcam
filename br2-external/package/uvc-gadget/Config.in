config BR2_PACKAGE_UVC_GADGET
	bool "uvc-gadget"
	help
	  UVC gadget userspace application (peterbay fork, used by showmewebcam).
	  Bridges camera frames from a V4L2 capture device (-v) to a UVC gadget
	  output device (-u), making the board enumerate as a USB webcam.

	  https://github.com/peterbay/uvc-gadget