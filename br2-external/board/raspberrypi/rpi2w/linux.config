# Raspberry Pi Zero 2 W - UVC Webcam Kernel Config Fragment
# Applied on top of bcm2709_defconfig (RPi kernel fork)

# USB Gadget support (UVC gadget)
CONFIG_USB_GADGET=y
CONFIG_USB_CONFIGFS=y
CONFIG_USB_CONFIGFS_F_UVC=y
CONFIG_USB_LIBCOMPOSITE=y
CONFIG_USB_F_UVC=y

# dwc_otg is the Pi's default USB controller driver (from bcm2709_defconfig).
# dwc2 must also be built-in so the dtoverlay=dwc2 in config.txt can swap to it for gadget mode.
# Dual-role mode so dr_mode=peripheral in the overlay works.
CONFIG_USB_DWC2=y
CONFIG_USB_DWC2_DUAL_ROLE=y

# Keep modules uncompressed so depmod/modprobe can resolve them reliably
# CONFIG_MODULE_COMPRESS is not set
# CONFIG_MODULE_COMPRESS_GZIP is not set
# CONFIG_MODULE_COMPRESS_XZ is not set
# CONFIG_MODULE_COMPRESS_ZSTD is not set
# CONFIG_MODULE_COMPRESS_ALL is not set

# CMA for camera buffers (increase from default 64M to 256M)
CONFIG_CMA_SIZE_MBYTES=256

# I2C for camera sensor control
CONFIG_I2C_BCM2835=y

# IMX477 camera supplies: the imx477 DT overlay models cam1_reg as a
# fixed-voltage regulator (regulator-fixed) with a GPIO enable line, so both
# the regulator core and the fixed-voltage + GPIO drivers are required.
# Without these the sensor probe fails with "failed to get regulators".
CONFIG_REGULATOR=y
CONFIG_REGULATOR_FIXED_VOLTAGE=y
CONFIG_REGULATOR_GPIO=y

# PWM for camera sensor
CONFIG_PWM_BCM2835=y