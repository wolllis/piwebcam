# Raspberry Pi Zero 2 W - UVC Webcam Kernel Config Fragment
# Applied on top of bcm2709_defconfig (RPi kernel fork)

# USB Gadget support (UVC gadget)
CONFIG_USB_GADGET=y
CONFIG_USB_CONFIGFS=y
CONFIG_USB_CONFIGFS_F_UVC=y
CONFIG_USB_LIBCOMPOSITE=y
CONFIG_USB_F_UVC=y

# dwc_otg is the Pi's default USB controller driver (from bcm2709_defconfig).
# dwc2 must also be built-in so the dtoverlay=dwc2 in config.txt can swap to it for gadget mode.
# Dual-role mode so dr_mode=peripheral in the overlay works.
CONFIG_USB_DWC2=y
CONFIG_USB_DWC2_DUAL_ROLE=y

# CMA for camera buffers (increase from default 64M to 256M)
CONFIG_CMA_SIZE_MBYTES=256

# I2C for camera sensor control
CONFIG_I2C_BCM2835=y

# PWM for camera sensor
CONFIG_PWM_BCM2835=y